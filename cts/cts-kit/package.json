{
  "name": "@manifesto-ai/cts-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Internal compliance test kit shared by LGW CTS suites",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false --outDir dist",
    "clean": "rm -rf dist",
    "lint": "echo 'lint not configured'",
    "test": "echo 'no tests for @manifesto-ai/cts-kit'",
    "test:coverage": "echo 'no coverage for @manifesto-ai/cts-kit'"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
