{
  "name": "@manifesto-ai/sdk",
  "version": "3.1.0",
  "description": "Manifesto SDK - Activation-first public API for the base runtime",
  "author": "eggplantiny <eggplantiny@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifesto-ai/core.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/manifesto-ai/core/issues"
  },
  "homepage": "https://github.com/manifesto-ai/core/tree/main/packages/sdk#readme",
  "keywords": [
    "manifesto",
    "sdk",
    "semantic-layer",
    "deterministic",
    "domain-state",
    "traceable",
    "snapshot"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false --outDir dist",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "echo 'lint not configured'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@manifesto-ai/compiler": "workspace:*",
    "@manifesto-ai/core": "workspace:*",
    "@manifesto-ai/host": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
