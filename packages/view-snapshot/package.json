{
  "name": "@manifesto-ai/view-snapshot",
  "version": "0.0.1",
  "description": "ViewSnapshot architecture - Agent-facing UI state representation",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "eggp",
    "email": "eggplantiny@gmail.com"
  },
  "homepage": "https://github.com/manifesto-ai/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifesto-ai/core.git",
    "directory": "packages/view-snapshot"
  },
  "bugs": {
    "url": "https://github.com/manifesto-ai/core/issues"
  },
  "keywords": ["manifesto", "view-snapshot", "ai", "agent", "ui-state"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js",
      "require": "./dist/types/index.cjs"
    },
    "./engine": {
      "types": "./dist/engine/index.d.ts",
      "import": "./dist/engine/index.js",
      "require": "./dist/engine/index.cjs"
    },
    "./builders": {
      "types": "./dist/builders/index.d.ts",
      "import": "./dist/builders/index.js",
      "require": "./dist/builders/index.cjs"
    },
    "./guards": {
      "types": "./dist/guards/index.d.ts",
      "import": "./dist/guards/index.js",
      "require": "./dist/guards/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/types/index.ts src/engine/index.ts src/builders/index.ts src/guards/index.ts --dts --format esm,cjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@manifesto-ai/schema": "workspace:*",
    "@manifesto-ai/engine": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
