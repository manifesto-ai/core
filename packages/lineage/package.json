{
  "name": "@manifesto-ai/lineage",
  "version": "3.10.1",
  "description": "Manifesto Lineage - decorator runtime for seal-aware continuity, history, and restore",
  "author": "eggplantiny <eggplantiny@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifesto-ai/core.git",
    "directory": "packages/lineage"
  },
  "bugs": {
    "url": "https://github.com/manifesto-ai/core/issues"
  },
  "homepage": "https://github.com/manifesto-ai/core/tree/main/packages/lineage#readme",
  "keywords": [
    "manifesto",
    "lineage",
    "world-protocol",
    "dag",
    "compliance"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false --outDir dist && node ../../scripts/check-public-surface.mjs packages/lineage",
    "clean": "rm -rf dist",
    "lint": "echo 'lint not configured'",
    "test": "pnpm run test:runtime && pnpm run test:types",
    "test:runtime": "node ../../node_modules/vitest/vitest.mjs run",
    "test:types": "node ../../node_modules/typescript/bin/tsc -p tsconfig.types.json --noEmit",
    "test:coverage": "node ../../node_modules/vitest/vitest.mjs run --coverage",
    "test:watch": "node ../../node_modules/vitest/vitest.mjs"
  },
  "peerDependencies": {
    "@manifesto-ai/core": "^2.12.0"
  },
  "dependencies": {
    "@manifesto-ai/sdk": "workspace:*"
  },
  "devDependencies": {
    "@manifesto-ai/core": "workspace:*",
    "@manifesto-ai/cts-kit": "workspace:*",
    "typescript": "^5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist"
  ]
}
