{
  "name": "@manifesto-ai/lineage",
  "version": "3.1.0",
  "description": "Manifesto Lineage - decorator runtime for seal-aware continuity, history, and restore",
  "author": "eggplantiny <eggplantiny@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifesto-ai/core.git",
    "directory": "packages/lineage"
  },
  "bugs": {
    "url": "https://github.com/manifesto-ai/core/issues"
  },
  "homepage": "https://github.com/manifesto-ai/core/tree/main/packages/lineage#readme",
  "keywords": [
    "manifesto",
    "lineage",
    "world-protocol",
    "dag",
    "compliance"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false --outDir dist",
    "clean": "rm -rf dist",
    "lint": "echo 'lint not configured'",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@manifesto-ai/core": "^2.0.0"
  },
  "dependencies": {
    "@manifesto-ai/sdk": "workspace:*"
  },
  "devDependencies": {
    "@manifesto-ai/core": "workspace:*",
    "@manifesto-ai/cts-kit": "workspace:*",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist"
  ]
}
