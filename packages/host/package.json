{
  "name": "@manifesto-ai/host",
  "version": "2.9.0",
  "description": "Manifesto Host - Effect execution runtime for @manifesto-ai/core",
  "author": "eggplantiny <eggplantiny@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifesto-ai/core.git",
    "directory": "packages/host"
  },
  "bugs": {
    "url": "https://github.com/manifesto-ai/core/issues"
  },
  "homepage": "https://github.com/manifesto-ai/core/tree/main/packages/host#readme",
  "keywords": [
    "manifesto",
    "effects",
    "runtime",
    "state-management",
    "deterministic",
    "effect-handler"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false --outDir dist",
    "clean": "rm -rf dist",
    "lint": "echo 'lint not configured'",
    "test": "node ../../node_modules/vitest/vitest.mjs run",
    "test:coverage": "node ../../node_modules/vitest/vitest.mjs run --coverage",
    "test:watch": "node ../../node_modules/vitest/vitest.mjs"
  },
  "peerDependencies": {
    "@manifesto-ai/core": "^2.12.0"
  },
  "devDependencies": {
    "@manifesto-ai/core": "workspace:*",
    "typescript": "^6.0.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "files": [
    "dist"
  ]
}
