{
  "name": "@manifesto-ai/ui",
  "version": "0.0.1",
  "description": "Framework-agnostic UI semantic layer for Manifesto (field registry, semantic registry, adapters)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./registry": {
      "types": "./dist/registry/index.d.ts",
      "import": "./dist/registry/index.mjs",
      "require": "./dist/registry/index.cjs"
    },
    "./semantic": {
      "types": "./dist/semantic/index.d.ts",
      "import": "./dist/semantic/index.mjs",
      "require": "./dist/semantic/index.cjs"
    },
    "./adapter": {
      "types": "./dist/adapter/index.d.ts",
      "import": "./dist/adapter/index.mjs",
      "require": "./dist/adapter/index.cjs"
    },
    "./src/*": "./src/*"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/registry/index.ts src/semantic/index.ts src/adapter/index.ts --dts --format esm,cjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@manifesto-ai/engine": "workspace:*",
    "@manifesto-ai/schema": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
