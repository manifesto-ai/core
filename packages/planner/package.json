{
  "name": "@manifesto-ai/planner",
  "version": "0.2.0",
  "description": "Manifesto Planner - decorator runtime for foresight, simulation, and strategy over governed worlds",
  "author": "eggplantiny <eggplantiny@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifesto-ai/core.git",
    "directory": "packages/planner"
  },
  "bugs": {
    "url": "https://github.com/manifesto-ai/core/issues"
  },
  "homepage": "https://github.com/manifesto-ai/core/tree/main/packages/planner#readme",
  "keywords": [
    "manifesto",
    "planner",
    "simulation",
    "strategy",
    "governance"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false --outDir dist && node ../../scripts/check-public-surface.mjs packages/planner",
    "clean": "rm -rf dist",
    "lint": "echo 'lint not configured'",
    "test": "pnpm run test:runtime && pnpm run test:types",
    "test:runtime": "vitest run",
    "test:types": "tsc -p tsconfig.types.json --noEmit",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@manifesto-ai/governance": "workspace:*",
    "@manifesto-ai/sdk": "workspace:*"
  },
  "devDependencies": {
    "@manifesto-ai/core": "workspace:*",
    "@manifesto-ai/lineage": "workspace:*",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "files": [
    "dist"
  ]
}
