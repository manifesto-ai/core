{
  "name": "@manifesto-ai/react",
  "version": "0.0.1",
  "description": "React integration for Manifesto DSL Engine",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "eggp",
    "email": "eggplantiny@gmail.com"
  },
  "homepage": "https://github.com/manifesto-ai/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifesto-ai/core.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/manifesto-ai/core/issues"
  },
  "keywords": ["manifesto", "react", "form", "dsl", "ai", "hooks", "components"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.mjs",
      "require": "./dist/hooks/index.cjs"
    },
    "./styles": "./dist/styles/index.css",
    "./styles.css": "./dist/styles/index.css",
    "./src/*": "./src/*"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/hooks/index.ts --dts --format esm,cjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@manifesto-ai/engine": "workspace:*",
    "@manifesto-ai/schema": "workspace:*",
    "@manifesto-ai/ui": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
