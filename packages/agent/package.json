{
  "name": "@manifesto-ai/agent",
  "version": "0.3.0",
  "description": "Session layer that executes LLM as a pure policy function and standardizes all side effects as Effects",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "manifesto",
    "ai",
    "agent",
    "llm",
    "policy",
    "effect",
    "session",
    "runtime"
  ],
  "author": "Manifesto Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifesto-ai/core.git",
    "directory": "packages/agent"
  },
  "homepage": "https://github.com/manifesto-ai/core/tree/main/packages/agent#readme",
  "bugs": {
    "url": "https://github.com/manifesto-ai/core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@manifesto-ai/core": "^0.3.0"
  },
  "devDependencies": {
    "@manifesto-ai/core": "workspace:*",
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.9",
    "tsup": "^8.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
