{
  "name": "@manifesto-ai/projection-ui",
  "version": "0.2.0",
  "description": "UI Projection layer for Manifesto AI - converts domain policies to UI states",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@manifesto-ai/core": "^0.2.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@manifesto-ai/core": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^26.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9",
    "zod": "^3.24.1"
  },
  "keywords": [
    "manifesto",
    "ai",
    "ui",
    "projection",
    "field-policy",
    "react"
  ],
  "author": "Manifesto Team",
  "license": "MIT"
}
