{
  "name": "@manifesto-ai/engine",
  "version": "0.0.1",
  "description": "Core DSL engine - expression evaluator, dependency tracker, schema loader",
  "type": "module",
  "license": "MIT",
  "author": {
    "name": "eggp",
    "email": "eggplantiny@gmail.com"
  },
  "homepage": "https://github.com/manifesto-ai/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifesto-ai/core.git",
    "directory": "packages/engine"
  },
  "bugs": {
    "url": "https://github.com/manifesto-ai/core/issues"
  },
  "keywords": ["manifesto", "engine", "form", "dsl", "ai", "runtime"],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./evaluator": {
      "types": "./dist/evaluator/index.d.ts",
      "import": "./dist/evaluator/index.mjs",
      "require": "./dist/evaluator/index.cjs"
    },
    "./tracker": {
      "types": "./dist/tracker/index.d.ts",
      "import": "./dist/tracker/index.mjs",
      "require": "./dist/tracker/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts src/evaluator/index.ts src/tracker/index.ts --dts --format esm,cjs",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@manifesto-ai/schema": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
