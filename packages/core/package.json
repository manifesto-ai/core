{
  "name": "@manifesto-ai/core",
  "version": "5.1.0",
  "description": "Manifesto Core - Pure semantic calculator for deterministic state computation",
  "author": "eggplantiny <eggplantiny@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifesto-ai/core.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/manifesto-ai/core/issues"
  },
  "homepage": "https://github.com/manifesto-ai/core/tree/main/packages/core#readme",
  "keywords": [
    "manifesto",
    "state-management",
    "deterministic",
    "semantic",
    "traceable",
    "immutable",
    "pure-computation"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && tsup && tsc -p tsconfig.build.json --emitDeclarationOnly --declarationMap false --outDir dist",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "node ../../scripts/run-biome.mjs check src",
    "test": "node ../../scripts/run-vitest.mjs run",
    "test:coverage": "node ../../scripts/run-vitest.mjs run --coverage"
  },
  "peerDependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@manifesto-ai/cts-kit": "workspace:*",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "zod": "^4.4.3"
  }
}
