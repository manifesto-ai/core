{
  "name": "@manifesto-ai/core",
  "version": "0.3.0",
  "description": "AI Native Semantic Layer for SaaS Business Logic",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./projection": {
      "types": "./dist/projection/index.d.ts",
      "import": "./dist/projection/index.js"
    },
    "./agent": {
      "types": "./dist/agent/index.d.ts",
      "import": "./dist/agent/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "manifesto",
    "ai",
    "semantic",
    "domain",
    "dsl"
  ],
  "author": "Manifesto Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifesto-ai/core.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/manifesto-ai/core/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/manifesto-ai/core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^2.1.9",
    "typescript": "^5.7.2",
    "vitest": "^2.1.9"
  }
}
