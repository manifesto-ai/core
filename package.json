{
  "name": "@manifesto-ai/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Semantic layer for deterministic domain state",
  "homepage": "https://docs.manifesto-ai.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manifesto-ai/core.git"
  },
  "keywords": [
    "manifesto",
    "semantic-layer",
    "deterministic",
    "domain-state",
    "traceable",
    "snapshot",
    "pure-computation",
    "schema-first"
  ],
  "type": "module",
  "packageManager": "pnpm@9.15.2",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "turbo run build --filter=@manifesto-ai/core --filter=@manifesto-ai/host --filter=@manifesto-ai/world --filter=@manifesto-ai/compiler --filter=@manifesto-ai/sdk --filter=@manifesto-ai/codegen",
    "dev": "turbo run dev",
    "lint": "turbo run lint --filter=@manifesto-ai/core --filter=@manifesto-ai/host --filter=@manifesto-ai/world --filter=@manifesto-ai/compiler --filter=@manifesto-ai/sdk --filter=@manifesto-ai/codegen",
    "test": "turbo run test --filter=@manifesto-ai/core --filter=@manifesto-ai/host --filter=@manifesto-ai/world --filter=@manifesto-ai/compiler --filter=@manifesto-ai/sdk --filter=@manifesto-ai/codegen",
    "test:coverage": "turbo run test:coverage --filter=@manifesto-ai/core --filter=@manifesto-ai/host --filter=@manifesto-ai/world --filter=@manifesto-ai/compiler --filter=@manifesto-ai/sdk --filter=@manifesto-ai/codegen",
    "check:no-app-imports": "node scripts/check-no-app-imports.mjs",
    "bench:core-host-world": "node scripts/bench-core-host-world.mjs",
    "clean": "turbo run clean && rm -rf node_modules",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:archive": "node scripts/archive-docs.mjs",
    "docs:mel-grammar": "node scripts/update-mel-grammar.mjs",
    "docs:governance-check": "node scripts/check-doc-governance.mjs",
    "docs:api:clean": "rm -rf docs/api"
  },
  "devDependencies": {
    "@vercel/analytics": "^1.6.1",
    "@vitest/coverage-v8": "^4.1.0",
    "mermaid": "^11.12.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "turbo": "^2.8.20",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "pnpm": {
    "overrides": {
      "@hono/node-server": "1.19.9",
      "esbuild": "0.27.2",
      "hono": "4.11.7",
      "lodash-es": "4.17.23",
      "preact": "10.28.2"
    }
  }
}
